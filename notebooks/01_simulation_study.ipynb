   "source": [
    "{\n",
    " \"cells\": [\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"# Adaptive Caliper Selection for Propensity Score Matching\\n\",\n",
    "    \"\\n\",\n",
    "    \"## A Multi-Objective Optimization Framework\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Authors:** Perkins Watambwa et al.  \\n\",\n",
    "    \"**Institution:** Centre for Sexual Health and HIV/AIDS Research (CeSHHAR), Zimbabwe\\n\",\n",
    "    \"\\n\",\n",
    "    \"---\\n\",\n",
    "    \"\\n\",\n",
    "    \"This notebook implements the Monte Carlo simulation study for evaluating the Adaptive Caliper Selection (ACS) algorithm against fixed-caliper approaches in propensity score matching.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"import sys\\n\",\n",
    "    \"sys.path.insert(0, '../src')\\n\",\n",
    "    \"\\n\",\n",
    "    \"import numpy as np\\n\",\n",
    "    \"import pandas as pd\\n\",\n",
    "    \"import matplotlib.pyplot as plt\\n\",\n",
    "    \"import seaborn as sns\\n\",\n",
    "    \"from pathlib import Path\\n\",\n",
    "    \"import warnings\\n\",\n",
    "    \"warnings.filterwarnings('ignore')\\n\",\n",
    "    \"\\n\",\n",
    "    \"from config import *\\n\",\n",
    "    \"from data_generator import DataGenerator, generate_simulation_scenarios\\n\",\n",
    "    \"from matching import PropensityScoreMatcher, compute_balance_statistics, compute_max_abs_smd\\n\",\n",
    "    \"from adaptive_caliper import AdaptiveCaliperSelector, run_acs_analysis\\n\",\n",
    "    \"from treatment_effect import evaluate_treatment_effect_estimation\\n\",\n",
    "    \"from simulation_runner import run_scenario_simulation, run_full_simulation, summarize_results\\n\",\n",
    "    \"from visualization import *\\n\",\n",
    "    \"\\n\",\n",
    "    \"plt.rcParams.update(PLT_PARAMS)\\n\",\n",
    "    \"print(f\\\"Output directory: {OUTPUT_DIR}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 1. Data Generating Process Demonstration\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"generator = DataGenerator(seed=42)\\n\",\n",
    "    \"\\n\",\n",
    "    \"df = generator.generate_dataset(\\n\",\n",
    "    \"    n=1000,\\n\",\n",
    "    \"    treatment_prevalence=0.5,\\n\",\n",
    "    \"    overlap_level=0.6,\\n\",\n",
    "    \"    confounding_strength=1.0\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"e_hat = generator.estimate_propensity_scores(df)\\n\",\n",
    "    \"df['e_hat'] = e_hat\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"Dataset shape: {df.shape}\\\")\\n\",\n",
    "    \"print(f\\\"\\\\nTreatment distribution:\\\")\\n\",\n",
    "    \"print(df['Z'].value_counts())\\n\",\n",
    "    \"print(f\\\"\\\\nCorrelation (true vs estimated PS): {np.corrcoef(df['e_true'], df['e_hat'])[0,1]:.4f}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig = plot_ps_distribution(df, ps_col='e_hat', \\n\",\n",
    "    \"                           title='Propensity Score Distribution (Medium Overlap)',\\n\",\n",
    "    \"                           save_path=FIGURES_DIR / 'ps_distribution_demo.png')\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 2. Adaptive Caliper Selection Algorithm\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"covariate_cols = [f'X{i+1}' for i in range(6)]\\n\",\n",
    "    \"\\n\",\n",
    "    \"selector = AdaptiveCaliperSelector(seed=42)\\n\",\n",
    "    \"selector.fit(df, covariate_cols=covariate_cols)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Pareto Frontier:\\\")\\n\",\n",
    "    \"print(selector.get_frontier_dataframe().to_string(index=False))\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"results = {}\\n\",\n",
    "    \"for criterion in ['balance', 'knee', 'weighted']:\\n\",\n",
    "    \"    result = selector.select_optimal(criterion)\\n\",\n",
    "    \"    results[criterion] = result.optimal_caliper\\n\",\n",
    "    \"    print(f\\\"\\\\n{criterion.upper()} Criterion:\\\")\\n\",\n",
    "    \"    print(f\\\"  Optimal caliper: {result.optimal_caliper:.3f} SD\\\")\\n\",\n",
    "    \"    print(f\\\"  Max |SMD|: {result.balance_at_optimal:.4f}\\\")\\n\",\n",
    "    \"    print(f\\\"  Retention: {result.retention_at_optimal:.2%}\\\")\\n\",\n",
    "    \"    print(f\\\"  N matched: {result.n_matched_at_optimal}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig = plot_pareto_frontier(selector, \\n\",\n",
    "    \"                           title='Pareto Frontier: Balance vs. Retention Trade-off',\\n\",\n",
    "    \"                           highlight_optimal=results,\\n\",\n",
    "    \"                           save_path=FIGURES_DIR / 'pareto_frontier_demo.png')\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 3. Balance Diagnostics\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"before_balance = compute_balance_statistics(df, covariate_cols)\\n\",\n",
    "    \"\\n\",\n",
    "    \"matcher = PropensityScoreMatcher(caliper=results['balance'], seed=42)\\n\",\n",
    "    \"matcher.fit(df['e_hat'].values, df['Z'].values)\\n\",\n",
    "    \"matched_df = matcher.get_matched_data(df)\\n\",\n",
    "    \"\\n\",\n",
    "    \"after_balance = compute_balance_statistics(matched_df, covariate_cols)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Balance Before Matching:\\\")\\n\",\n",
    "    \"print(before_balance[['covariate', 'mean_treated', 'mean_control', 'smd', 'abs_smd']].to_string(index=False))\\n\",\n",
    "    \"print(f\\\"\\\\nMax |SMD| before: {before_balance['abs_smd'].max():.4f}\\\")\\n\",\n",
    "    \"print(f\\\"Max |SMD| after: {after_balance['abs_smd'].max():.4f}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig = plot_love_plot(before_balance, after_balance,\\n\",\n",
    "    \"                     title='Love Plot: Covariate Balance Improvement',\\n\",\n",
    "    \"                     save_path=FIGURES_DIR / 'love_plot_demo.png')\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 4. Treatment Effect Estimation\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"te_results = evaluate_treatment_effect_estimation(matched_df, TRUE_TREATMENT_EFFECT)\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(\\\"Treatment Effect Estimation:\\\")\\n\",\n",
    "    \"print(f\\\"  True ATT: {TRUE_TREATMENT_EFFECT}\\\")\\n\",\n",
    "    \"print(f\\\"  Estimated ATT: {te_results['att']:.4f}\\\")\\n\",\n",
    "    \"print(f\\\"  Bias: {te_results['bias']:.4f}\\\")\\n\",\n",
    "    \"print(f\\\"  SE: {te_results['se']:.4f}\\\")\\n\",\n",
    "    \"print(f\\\"  95% CI: [{te_results['ci_lower']:.4f}, {te_results['ci_upper']:.4f}]\\\")\\n\",\n",
    "    \"print(f\\\"  Coverage: {te_results['coverage']}\\\")\\n\",\n",
    "    \"print(f\\\"  N pairs: {te_results['n_pairs']}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 5. Monte Carlo Simulation (Single Scenario Test)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"test_scenario = {\\n\",\n",
    "    \"    'scenario_id': 1,\\n\",\n",
    "    \"    'n': 500,\\n\",\n",
    "    \"    'treatment_prevalence': 0.5,\\n\",\n",
    "    \"    'overlap_name': 'medium',\\n\",\n",
    "    \"    'overlap_level': 0.6,\\n\",\n",
    "    \"    'confounding_name': 'strong',\\n\",\n",
    "    \"    'confounding_strength': 1.0,\\n\",\n",
    "    \"    'description': 'Test scenario'\\n\",\n",
    "    \"}\\n\",\n",
    "    \"\\n\",\n",
    "    \"test_results = run_scenario_simulation(\\n\",\n",
    "    \"    test_scenario,\\n\",\n",
    "    \"    n_replications=50,\\n\",\n",
    "    \"    n_jobs=1,\\n\",\n",
    "    \"    verbose=True\\n\",\n",
    "    \")\\n\",\n",
    "    \"\\n\",\n",
    "    \"print(f\\\"\\\\nResults shape: {test_results.shape}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"summary = test_results.groupby('method').agg({\\n\",\n",
    "    \"    'n_matched': 'mean',\\n\",\n",
    "    \"    'retention': 'mean',\\n\",\n",
    "    \"    'max_smd': 'mean',\\n\",\n",
    "    \"    'bias': ['mean', lambda x: np.mean(np.abs(x))],\\n\",\n",
    "    \"    'mse': 'mean',\\n\",\n",
    "    \"    'coverage': 'mean'\\n\",\n",
    "    \"}).round(4)\\n\",\n",
    "    \"\\n\",\n",
    "    \"summary.columns = ['N Matched', 'Retention', 'Max |SMD|', 'Mean Bias', '|Bias|', 'MSE', 'Coverage']\\n\",\n",
    "    \"print(\\\"\\\\nSummary by Method:\\\")\\n\",\n",
    "    \"print(summary)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig = plot_method_comparison_boxplot(test_results, metric='bias',\\n\",\n",
    "    \"                                     title='Bias Distribution by Method (Test Scenario)',\\n\",\n",
    "    \"                                     save_path=FIGURES_DIR / 'bias_boxplot_test.png')\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig = plot_method_comparison_boxplot(test_results, metric='mse',\\n\",\n",
    "    \"                                     title='MSE Distribution by Method (Test Scenario)',\\n\",\n",
    "    \"                                     save_path=FIGURES_DIR / 'mse_boxplot_test.png')\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 6. Full Simulation Study\\n\",\n",
    "    \"\\n\",\n",
    "    \"**Note:** Running the full simulation with 1000 replications across 54 scenarios takes several hours. Adjust `n_replications` for testing.\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"scenarios = generate_all_scenarios()\\n\",\n",
    "    \"print(f\\\"Total scenarios: {len(scenarios)}\\\")\\n\",\n",
    "    \"print(\\\"\\\\nFirst 5 scenarios:\\\")\\n\",\n",
    "    \"for s in scenarios[:5]:\\n\",\n",
    "    \"    print(f\\\"  {s['scenario_id']}: n={s['n']}, prev={s['treatment_prevalence']}, \\\"\\n\",\n",
    "    \"          f\\\"overlap={s['overlap_name']}, conf={s['confounding_name']}\\\")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"# Uncomment to run full simulation (takes several hours)\\n\",\n",
    "    \"# full_results = run_full_simulation(\\n\",\n",
    "    \"#     scenarios=scenarios,\\n\",\n",
    "    \"#     n_replications=1000,\\n\",\n",
    "    \"#     n_jobs=-1,\\n\",\n",
    "    \"#     save_intermediate=True,\\n\",\n",
    "    \"#     verbose=True\\n\",\n",
    "    \"# )\\n\",\n",
    "    \"\\n\",\n",
    "    \"# For testing, run with fewer replications:\\n\",\n",
    "    \"full_results = run_full_simulation(\\n\",\n",
    "    \"    scenarios=scenarios[:6],\\n\",\n",
    "    \"    n_replications=20,\\n\",\n",
    "    \"    n_jobs=1,\\n\",\n",
    "    \"    save_intermediate=True,\\n\",\n",
    "    \"    verbose=True\\n\",\n",
    "    \")\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"summary_df = summarize_results(full_results)\\n\",\n",
    "    \"summary_df.to_csv(TABLES_DIR / 'simulation_summary.csv', index=False)\\n\",\n",
    "    \"print(f\\\"Summary shape: {summary_df.shape}\\\")\\n\",\n",
    "    \"summary_df.head(10)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"method_table = create_summary_table(summary_df, save_path=TABLES_DIR / 'method_summary.csv')\\n\",\n",
    "    \"print(\\\"\\\\nOverall Method Performance:\\\")\\n\",\n",
    "    \"print(method_table)\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 7. Results Visualization\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig = plot_method_comparison_boxplot(full_results, metric='bias',\\n\",\n",
    "    \"                                     title='Bias Distribution Across All Scenarios',\\n\",\n",
    "    \"                                     save_path=FIGURES_DIR / 'bias_boxplot_full.png')\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig = plot_method_comparison_boxplot(full_results, metric='coverage',\\n\",\n",
    "    \"                                     title='Coverage Probability Across All Scenarios',\\n\",\n",
    "    \"                                     save_path=FIGURES_DIR / 'coverage_boxplot_full.png')\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"code\",\n",
    "   \"execution_count\": null,\n",
    "   \"metadata\": {},\n",
    "   \"outputs\": [],\n",
    "   \"source\": [\n",
    "    \"fig = create_scenario_comparison_figure(summary_df,\\n\",\n",
    "    \"                                        save_path=FIGURES_DIR / 'scenario_comparison.png')\\n\",\n",
    "    \"plt.show()\"\n",
    "   ]\n",
    "  },\n",
    "  {\n",
    "   \"cell_type\": \"markdown\",\n",
    "   \"metadata\": {},\n",
    "   \"source\": [\n",
    "    \"## 8. Conclusions\\n\",\n",
    "    \"\\n\",\n",
    "    \"The simulation study demonstrates that:\\n\",\n",
    "    \"\\n\",\n",
    "    \"1. **ACS methods adapt** to dataset characteristics, selecting different calipers based on overlap and sample size\\n\",\n",
    "    \"2. **ACS-Balance** achieves the best covariate balance while maintaining reasonable sample retention\\n\",\n",
    "    \"3. **ACS-Weighted** provides a good compromise between bias and variance\\n\",\n",
    "    \"4. **Fixed calipers** may be suboptimal in scenarios with limited overlap or asymmetric sample sizes\"\n",
    "   ]\n",
    "  }\n",
    " ],\n",
